<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xht.auth.authentication.dao.mapper.Oauth2ThirdAccountMapper">

    <insert id="insertUser" parameterType="com.xht.auth.authentication.entity.Oauth2ThirdAccountEntity">
        insert into sys_user (id, user_name,
                              nick_name,
                              pass_word_plain_text,
                              user_status, user_avatar, del_flag)
            value (#{entity.userId}, #{entity.nickName}, #{entity.nickName}, #{entity.passWordPlainText},
                   #{entity.userStatus}, #{entity.userAvatar}, 0)
    </insert>
    <insert id="insertUserInfo" parameterType="com.xht.auth.authentication.entity.Oauth2ThirdAccountEntity">
        insert into sys_user_detail (user_id, del_flag)
            value (#{entity.userId}, 0)
    </insert>
</mapper>
